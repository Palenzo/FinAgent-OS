# Application
APP_ENV=development
SECRET_KEY=your_secret_key_here

# PostgreSQL
POSTGRES_USER=finagent
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=finagent_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://finagent:your_db_password@postgres:5432/finagent_db

# Redis
REDIS_URL=redis://redis:6379/0

# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# SendGrid
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=you@example.com
ALERT_EMAIL_RECIPIENT=you@example.com

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
